{
  "name": "@blueneon/zip-it",
  "version": "1.0.2",
  "description": "Browser download manager for large file batches (10 GB+). OPFS staging, pause/resume, ZIP streaming, IndexedDB resumability — zero server code.",
  "author": {
    "name": "Rochak Sulu",
    "url": "https://github.com/ARES-AM2003"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/zip-it.cjs",
  "module": "./dist/zip-it.mjs",
  "types": "./dist/zip-it.d.ts",
  "exports": {
    ".": {
      "import": "./dist/zip-it.mjs",
      "require": "./dist/zip-it.cjs",
      "types": "./dist/zip-it.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "download-manager",
    "opfs",
    "origin-private-file-system",
    "file-system-access-api",
    "zip-streaming",
    "resumable-download",
    "batch-download",
    "large-file-download",
    "browser",
    "webworker",
    "web-worker",
    "zip-compression",
    "client-side-zip",
    "fflate",
    "streamsaver",
    "indexeddb",
    "pause-resume",
    "file-download",
    "streaming",
    "archive"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ARES-AM2003/Zip-it-package.git"
  },
  "homepage": "https://github.com/ARES-AM2003/Zip-it-package#readme",
  "bugs": {
    "url": "https://github.com/ARES-AM2003/Zip-it-package/issues"
  },
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "streamsaver": "^2.0.6"
  },
  "peerDependenciesMeta": {
    "streamsaver": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/streamsaver": "^2.0.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  }
}